# =============================================================================
# Client (Vite) .env – copy this file to .env and replace values with your own.
# All client env vars must be prefixed with VITE_ to be exposed to the app.
# =============================================================================

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
# Backend base URL (no trailing slash). Use your server URL or ngrok URL in dev.
VITE_API_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Google OAuth (login – must match server GOOGLE_CLIENT_ID)
# -----------------------------------------------------------------------------
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# -----------------------------------------------------------------------------
# Development / debugging (optional)
# -----------------------------------------------------------------------------
# Set to true when using ngrok so the client sends ngrok-skip-browser-warning
VITE_NGROK=false

# Skip Google login and use app without auth (dev only)
VITE_NO_AUTH=false

# Enable dev tools panel in the app. When true, ADMIN and OWNER see the Inbox
# “Mocking” switch (default on) to skip real Twilio on outbound SMS in dev.
VITE_DEVTOOLS=false

# -----------------------------------------------------------------------------
# Messaging / MMS (optional note)
# -----------------------------------------------------------------------------
# Image uploads and storage use the API + server-side Supabase credentials.
# The CRM renders image URLs returned by the API; you do not need VITE_ Supabase
# keys in the client for standard MMS flows.
