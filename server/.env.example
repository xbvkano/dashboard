# =============================================================================
# Server .env – copy to .env and replace values with your own.
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
# development | production | test (Jest sets test automatically)
# NODE_ENV=development

# HS256 secrets for API Bearer tokens (issued on POST /login). Required when NODE_ENV=production.
# JWT_ADMIN_SECRET=your-long-random-admin-secret
# JWT_EMPLOYEE_SECRET=your-long-random-employee-secret
# Optional access token lifetime (default 24h), e.g. 12h or 3600
# JWT_ACCESS_EXPIRES_IN=24h
# Optional: max seconds after token exp before POST /auth/refresh refuses (default 90 days)
# JWT_REFRESH_MAX_EXPIRED_SEC=7776000

# Port the HTTP server listens on (default: 3000)
PORT=3000

# Allow X-Messaging-Mock-Sms on POST /messaging/conversations/:id/messages when NODE_ENV
# is production (by default mock header is ignored in production). Local dev does not need this.
# ALLOW_MESSAGING_MOCK_SMS=1

# When true/1 and NODE_ENV is not production: if a request has no x-user-id (and no x-user-name),
# the server fills them so /users/me and messaging APIs work with client VITE_NO_AUTH.
# Ignored in production. Defaults match prisma seed (Alice id 1, userName dev_seed_admin).
# NO_AUTH=false
# NO_AUTH_USER_ID=1
# NO_AUTH_USER_NAME=dev_seed_admin
# (Client sends x-user-id per tab; second dev admin in seed is id 2 / dev_seed_admin_2)

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mydb
# After `npx prisma db seed`: password admin for JWT testing (NO_AUTH=false) — userName = Phone field
# 7025550199 / SeedAdmin!99 (role ADMIN, id 3). Also: dev_seed_admin_2 / devadmin2 (Bob, id 2).

# -----------------------------------------------------------------------------
# Google OAuth (login)
# -----------------------------------------------------------------------------
# Google Cloud Console → APIs & Services → Credentials (OAuth 2.0 Client IDs)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Must match an authorized redirect URI in Google Console (dev and prod)
GOOGLE_REDIRECT_URI=http://localhost:5173
# Comma-separated emails allowed to sign in as admin (if your app checks this)
ADMIN_EMAILS=admin@example.com

# -----------------------------------------------------------------------------
# Google Drive (invoice PDF uploads via drive.ts)
# -----------------------------------------------------------------------------
# Service account JSON as raw string, base64, or filesystem path to .json
GOOGLE_DRIVE_API_KEY=your-google-drive-api-key-or-json-path
# Optional: user OAuth refresh token when not using service account only
# GOOGLE_REFRESH_TOKEN=your-refresh-token

# -----------------------------------------------------------------------------
# SSL (optional – local HTTPS, e.g. mkcert)
# -----------------------------------------------------------------------------
# SSL_KEY_PATH=/path/to/key.pem
# SSL_CERT_PATH=/path/to/cert.pem

# -----------------------------------------------------------------------------
# Mailtrap (SMTP / transactional email – invoicesController)
# -----------------------------------------------------------------------------
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=your-mailtrap-user
# Used as SMTP password and as Bearer token for Mailtrap API paths
MAILTRAP_API_KEY=your-mailtrap-api-key
MAILTRAP_FROM=no-reply@example.com

# -----------------------------------------------------------------------------
# Website server (API proxy – coupons, websiteApi routes)
# -----------------------------------------------------------------------------
# Base URL of the public website backend (no trailing slash). Required for
# /api/coupons and website API proxies; returns 503 if unset.
WEBSITE_SERVER_URL=https://your-website.example.com

# -----------------------------------------------------------------------------
# Twilio (SMS – reminders, unconfirmed alerts, CRM messaging, tests)
# -----------------------------------------------------------------------------
# Twilio Console → Account → API keys & tokens (or Account SID + Auth Token).
# Prefer API Keys + Secret for production; rotate Auth Token if compromised.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token-or-api-key-secret

# US A2P: attach your approved campaign to a Messaging Service and add your
# sender number(s) to that service. This app prefers Messaging Service for all
# outbound API calls when the SID below is set (omit TWILIO_FROM_NUMBER if you
# only use the service, or keep FROM as a fallback for local/scripts).
# Inbox/CRM outbound SMS uses the real Twilio API only when TWILIO_ACCOUNT_SID
# and TWILIO_AUTH_TOKEN are also set; Messaging Service SID alone is not enough.
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Fallback when TWILIO_MESSAGING_SERVICE_SID is unset: E.164 `from` address.
# Optional if you always send via Messaging Service only.
TWILIO_FROM_NUMBER=+15551234567

# Inbound SMS does not use this SID: configure “When a message comes in” on
# your Twilio number (or Messaging Service) → public HTTPS URL (e.g. POST
# /messaging/inbound). Dev: ngrok, etc.

# Console: Trust Hub → Brand; Regulatory Compliance → US A2P Campaign; link
# campaign to your Messaging Service and phone numbers; wait for approval.

# -----------------------------------------------------------------------------
# Supabase Storage (CRM MMS attachments — server only)
# -----------------------------------------------------------------------------
# Used to upload inbound Twilio media and outbound CRM images. The service role
# key must never be sent to the browser. Twilio fetches outbound MMS URLs from
# the public internet — use a bucket/path with public read, or Twilio cannot
# retrieve the file.
# Project URL: Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Service role key (Dashboard → Settings → API — keep secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Bucket **id** from Supabase → Storage (case-sensitive, must match exactly, e.g. Photos)
# Must exist in the same project as SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY
SUPABASE_STORAGE_BUCKET=messaging

# Appointment / screenshot vision uploads (separate bucket id from messaging). Public read recommended.
# Startup logs: [supabase-appointment] Bucket "<id>" OK (same Supabase project as above).
SUPABASE_STORAGE_BUCKET_APPOINTMENT=your-appointment-bucket-id

# Set to 1 to skip the post-upload HTTP HEAD check (tests set NODE_ENV=test automatically)
# MESSAGING_SKIP_MEDIA_PUBLIC_CHECK=0

# -----------------------------------------------------------------------------
# Pushover (optional — inbound SMS notifications to your phone)
# -----------------------------------------------------------------------------
# Create an application at https://pushover.net/ and use the app token + your user key.
# Notifications are rate-limited per conversation; skipped when someone is viewing the thread.
# PUSHOVER_APP_TOKEN=your-pushover-application-token
# PUSHOVER_USER_TOKEN=your-pushover-user-key
#
# Optional: base URL for admin deep links included in Pushover notifications (no trailing slash),
# e.g. https://dashboard.worldwideevidence.com
# DASHBOARD_PUBLIC_URL=

# -----------------------------------------------------------------------------
# Google Cloud Translation API (optional — “Translate to Portuguese” in inbox)
# -----------------------------------------------------------------------------
# OAuth client vars above are NOT used for Translation. Use an API key whose GCP project has
# “Cloud Translation API” enabled. See docs/translation-google-api.md for cost notes.
# GOOGLE_API_KEY=your-google-cloud-api-key
# Optional: separate key restricted to Translation API only (overrides GOOGLE_API_KEY for translate)
# GOOGLE_TRANSLATE_API_KEY=

# -----------------------------------------------------------------------------
# OpenAI (appointment extraction from threads / screenshot images)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# Optional overrides (defaults: gpt-4o-mini for text, gpt-4o for vision)
# OPENAI_EXTRACTION_MODEL=gpt-4o-mini
# OPENAI_VISION_MODEL=gpt-4o

# -----------------------------------------------------------------------------
# RentCast (property square footage when AI could not infer size — optional)
# -----------------------------------------------------------------------------
# RENTCAST_API_KEY=
# RENTCAST_BASE_URL=https://api.rentcast.io/v1
